# --- LLM (OpenRouter) ---
# Get a free key at https://openrouter.ai/keys
# If unset, the LLM signal gracefully falls back to a deterministic heuristic.
OPENROUTER_API_KEY= 

# OpenAI-compatible base URL for OpenRouter.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# A free-tier model works fine here.
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Seconds the LLM call is allowed before falling back to the heuristic.
LLM_TIMEOUT_SECONDS=8

# --- Engine ---
# How often (seconds) the event buffer is flushed and signals are recomputed.
FLUSH_INTERVAL_SECONDS=5
